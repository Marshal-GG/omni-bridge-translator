# ─────────────────────────────────────────────
# Omni Bridge — Environment Variables Template
# ─────────────────────────────────────────────
# This is the .env.example file. It contains all the required environment
# variable keys with empty values.
#
# To set up your own environment:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in the values in your new .env file
#
# The real .env file is in .gitignore and must NEVER be committed to Git.
# ─────────────────────────────────────────────

# Google OAuth 2.0 Web Client ID
# Used by: lib/core/services/auth_service.dart → GoogleSignInParams.clientId
# How to get it: Google Cloud Console → APIs & Services → Credentials
#                → OAuth 2.0 Client IDs → "Web client (auto created by Google Service)"
GOOGLE_CLIENT_ID=

# Redirect URL for browser after successful authentication
# Set this to your website URL (e.g., https://your-website.com/auth-success)
AUTH_SUCCESS_REDIRECT_URL=
